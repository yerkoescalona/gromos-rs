TITLE
Alanine dipeptide vacuum FEP/TI: perturbed bonded terms at lambda=0.125
Tests: perturbed quartic bond, cos-harmonic angle, improper, proper dihedral
END
SYSTEM
#      NPM      NSM
         1        0
END
INITIALISE
#  NTIVEL  NTISHK  NTINHT  NTINHB
        0       0       0       0
#  NTISHI  NTIRTC  NTICOM
        1       0       0
#  NTISTI
        0
#      IG   TEMPI
   210185     0.0
END
STEP
#   NSTLIM         T        DT
        10       0.0     0.002
END
BOUNDCOND
#      NTB    NDFMIN
         0         0
END
MULTIBATH
    weak-coupling
#   NBATHS
    1
#   TEMP0  TAU
    300.0  -1.0
#   DOFSET
    1
#   LAST   COM-BATH  IR-BATH
    12     1         1
END
COMTRANSROT
#     NSCM
    100000
END
PRINTOUT
#     NTPR      NTPP
         1         0
END
WRITETRAJ
#     NTWX     NTWSE      NTWV      NTWF      NTWE      NTWG      NTWB
         1         0         0         1         1         0         0
END
CONSTRAINT
#       NTC
        1
#       NTCP
        shake
#       NTCP0(1)
        0.0001
#       NTCS
        shake
#       NTCS0(1)
        0.0001
END
FORCE
#      NTF array
# bonds    angles    imp.     dihe     charge nonbonded
# H        H         H        H
     1        1         1        1     1  1
# NEGR    NRE(1)    NRE(2)    ...      NRE(NEGR)
     1     12
END
PAIRLIST
#       ALGORITHM       NSNB    RCUTP   RCUTL   SIZE    TYPE
        standard        1       0.8     1.4     auto    chargegroup
END
NONBONDED
#   NLRELE
         1
#    APPAK      RCRF     EPSRF  NSLFEXCL
       0.0       1.4      62.0         1
#   NSHAPE    ASHAPE    NA2CLC     TOLA2    EPSLS
        -1       1.4         2    0.1E-9      0.0
#      NKX       NKY       NKZ       NK2
        10        10        10      100.0
#      NGX       NGY       NGZ    NASORD    NFDORD    NALIAS    NSPORD
        32        32        32         3         2         3         4
#   NQEVAL    FACCUR    NRDGRD    NWRGDR
    100000       1.6         0         0
#    NLRLJ    SLVDNS
         0      33.3
END
POSITIONRES
#   NTPOR  NTPORB  NTPORS    CPOR
        0       0       0   0.0
END
PERTURBATION
#    NTG: 0..1 controls use of free-energy calculation.
#         1: calculate dH/dRLAM
#  NRDGL: 0 use initial RLAM from this block
#   RLAM: 0.0..1.0 initial value for lambda
#  DLAMT: rate of lambda increase (0=constant lambda)
# ALPHLJ: LJ soft-core parameter
#  ALPHC: Coulomb-RF soft-core parameter
#   NLAM: power dependence of lambda coupling
# NSCALE: 0=no scaling
#
#     NTG   NRDGL    RLAM   DLAMT
        1       0   0.125     0.0
#  ALPHLJ   ALPHC    NLAM  NSCALE
      0.3     0.6       1       0
END
