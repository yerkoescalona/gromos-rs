TITLE
CH4+1water FEP: minimal perturbed nonbonded test
CM(CH4)->dummy at RLAM=0.5, vacuum, 4 atoms, no twin-range.
Pure nonbonded FEP: only CM-OW LJ matters (CM charge=0, HW LJ=0).
END
SYSTEM
#      NPM      NSM
         1        1
END
INITIALISE
#  NTIVEL  NTISHK  NTINHT  NTINHB
        1       0       0       0
#  NTISHI  NTIRTC  NTICOM
        0       0       0
#  NTISTI
        0
#      IG   TEMPI
   210185     0.0
END
STEP
#   NSTLIM         T        DT
        1       0.0     0.002
END
BOUNDCOND
#      NTB    NDFMIN
         1         0
END
MULTIBATH
    weak-coupling
#   NBATHS
    1
#   TEMP0  TAU
    300.0  -1.0
#   DOFSET
    1
#   LAST   COM-BATH  IR-BATH
    4        1         1
END
COMTRANSROT
#     NSCM
    100000
END
PRINTOUT
#     NTPR      NTPP
         1         0
END
WRITETRAJ
#     NTWX     NTWSE      NTWV      NTWF      NTWE      NTWG      NTWB
         1         0         0         1         1         0         0
END
CONSTRAINT
#       NTC
        1
#       NTCP
        shake
#       NTCP0(1)
        0.0001
#       NTCS
        shake
#       NTCS0(1)
        0.0001
END
FORCE
#      NTF array
# bonds    angles    imp.     dihe     charge nonbonded
     1        1         1        1     1  1
# NEGR    NRE(1)    NRE(2)    ...      NRE(NEGR)
     2       1     4
END
PAIRLIST
#       ALGORITHM       NSNB    RCUTP   RCUTL   SIZE    TYPE
        standard        1       2.0     2.0     auto    chargegroup
END
NONBONDED
#   NLRELE
         1
#    APPAK      RCRF     EPSRF  NSLFEXCL
       0.0       2.0      78.5         1
#   NSHAPE    ASHAPE    NA2CLC     TOLA2    EPSLS
        -1       1.4         2    0.1E-9      0.0
#      NKX       NKY       NKZ       NK2
        10        10        10      100.0
#      NGX       NGY       NGZ    NASORD    NFDORD    NALIAS    NSPORD
        32        32        32         3         2         3       4
#   NQEVAL    FACCUR    NRDGRD    NWRGRD
    100000       1.6         0         0
#    NLRLJ    SLVDNS
         0      33.3
END
POSITIONRES
#   NTPOR  NTPORB  NTPORS    CPOR
        0       0       0   0.0
END
PERTURBATION
#     NTG   NRDGL    RLAM   DLAMT
        1       0   0.500     0.0
#  ALPHLJ   ALPHC    NLAM  NSCALE
      0.5     0.5       1       0
END
